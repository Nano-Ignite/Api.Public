          "CrossOriginIsolated": { "IsNone": true },
          "DeferredFetch": { "IsNone": true },
          "DeferredFetchMinimal": { "IsNone": true },
          "DisplayCapture": { "IsNone": true },
          "DocumentDomain": { "IsNone": true },
          "EncryptedMedia": { "IsNone": true },
          "ExecutionWhileNotRendered": { "IsNone": true },
          "ExecutionWhileOutOfViewport": { "IsNone": true },
          "FullScreen": { "IsNone": true },
          "Gamepad": { "IsNone": true },
          "Geolocation": { "IsNone": true },
          "Gyroscope": { "IsNone": true },
          "Hid": { "IsNone": true },
          "IdentityCredentialsGet": { "IsNone": true },
          "IdleDetection": { "IsNone": true },
          "LanguageDetector": { "IsNone": true },
          "LocalFonts": { "IsNone": true },
          "LayoutAnimations": { "IsNone": true },
          "LegacyImageFormats": { "IsNone": true },
          "Magnetometer": { "IsNone": true },
          "Microphone": { "IsNone": true },
          "Midi": { "IsNone": true },
          "OnDeviceSpeechRecognition": { "IsNone": true },
          "OtpCredentials": { "IsNone": true },
          "NavigationOverride": { "IsNone": true },
          "OversizedImages": { "IsNone": true },
          "Payment": { "IsNone": true },
          "PictureInPicture": { "IsNone": true },
          "PrivateStateTokenIssuance": { "IsNone": true },
          "PrivateStateTokenRedemption": { "IsNone": true },
          "PublickeyCredentialsCreate": { "IsNone": true },
          "PublicKeyCredentialsGet": { "IsNone": true },
          "ScreenWakeLock": { "IsNone": true },
          "Serial": { "IsNone": true },
          "SpeakerSelection": { "IsNone": true },
          "StorageAccess": { "IsNone": true },
