          "IsSelf": true
        },
        "Media": null,
        "Frames": null,
        "FencedFrames": null,
        "FrameAncestors": null,
        "Fonts": null,
        "Connections": null,
        "BaseUris": null,
        "Children": null,
        "Forms": {
          "IsNone": true
        },
        "Manifests": null,
        "TrustedTypes": null,
        "Sandbox": null,
        "PermissionsPolicy":
        {
          "Accelerometer": { "IsNone": true },
          "AmbientLightSensor": { "IsNone": true },
          "AriaNotify": { "IsNone": true },
