{
  "App": {
    "Version": "1.0.0.0",
    "ShutdownTimeout": 10,
    "Hosting": {
      "Root": "api",
      "Http": {
        "Ports": [
          8080
        ],
        "UseHttpsRedirection": false
      },
      "MultipartLimits": {
        "MaxUploadBytes": 33554432,
        "KeepAliveTimeout": 130
      }
    },
    "HttpPolicyHeaders": {
      "ContentType": {
        "NoSniff": true
      },
      "ReferrerPolicy": {
        "ReferrerPolicyHeader": "StrictOriginWhenCrossOrigin"
      },
      "FrameOptions": {
        "FrameOptionsPolicyHeader": "Deny"
      },
      "XssProtection": {
        "XssProtectionPolicyHeader": "FilterEnabledBlockMode",
        "ReportingUrl": null
      },
      "Csp": {
        "ReportOnly": false,
        "UpgradeInsecureRequests": false,
        "ReportTo": null,
        "Defaults": {
          "IsNone": true
        },
        "Scripts": {
          "IsSelf": true
        },
        "ScriptsElem": null,
        "ScriptsAttr": null,
        "Styles": {
