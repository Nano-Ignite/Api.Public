      "Cors": null,
      "Hsts": null,
      "Robots": null,
      "ForwardedHeaders": {
        "Headers": "All",
        "RequireHeaderSymmetry": true
      }
    },
    "ResponseCache": {
      "MaxSize": 1024,
      "MaxBodySize": 102400,
      "MaxAge": "00:20:00"
    },
    "ResponseCompression": {
      "UseGzip": true,
      "UseBrotli": true
    },
    "Session": null,
    "TimeZone": {
